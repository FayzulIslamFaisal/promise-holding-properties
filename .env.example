# =============================================================================
# Promise Holding Properties - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values
# cp .env.example .env.local

# Backend API Base URL (without trailing slash)
NEXT_PUBLIC_API_BASE_URL=https://spider.promiseassets.com/api

# Google OAuth Client ID (for Google Login)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Token cookie name
NEXT_PUBLIC_AUTH_COOKIE_NAME=php_token
